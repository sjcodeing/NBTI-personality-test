.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 我的类型区域 */
.my-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.section-label {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.label-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.my-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
  border-radius: 16rpx;
}

.my-badge {
  background: #1a1a2e;
  color: white;
  font-size: 22rpx;
  font-weight: bold;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.my-info {
  flex: 1;
}

.my-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
}

.my-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.my-check {
  font-size: 24rpx;
  color: #4caf50;
  font-weight: bold;
}

.hint-text {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 20rpx;
}

.type-grid-small {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.type-chip {
  padding: 12rpx 20rpx;
  background: #f0f0f0;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #333;
}

.type-chip.selected {
  background: #1a1a2e;
  color: white;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #ddd;
}

.divider-plus {
  font-size: 48rpx;
  color: #ff9800;
  font-weight: bold;
  padding: 0 20rpx;
}

/* 同事选择区域 */
.colleague-section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.colleague-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.colleague-card {
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.colleague-card.selected {
  border-color: #ff9800;
  background: #fff8e1;
}

.card-id {
  font-size: 22rpx;
  color: #999;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

/* 空提示 */
.empty-hint {
  text-align: center;
  padding: 60rpx;
}

.hint-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* ===== 结果区域 ===== */
.result-container {
  padding: 10rpx 0;
}

.result-header {
  text-align: center;
  padding: 50rpx 30rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(26,26,46,0.3);
}

.result-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.result-name {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  color: white;
  margin-bottom: 10rpx;
}

.result-alias {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  display: block;
}

.combination-card {
  background: white;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.combination-characters {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 36rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #f5f5f5, #eeeeee);
  border-radius: 16rpx;
}

.character-mini {
  text-align: center;
}

.character-id {
  font-size: 20rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.character-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.plus-sign {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9800;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
  color: #1a1a2e;
}

.result-description {
  margin-bottom: 36rpx;
}

.description-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

.result-analysis {
  margin-bottom: 36rpx;
}

.analysis-item {
  margin-bottom: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
}

.analysis-item.pros {
  background: #e8f5e9;
}

.analysis-item.cons {
  background: #fce4ec;
}

.analysis-item.dynamic {
  background: #e3f2fd;
}

.analysis-item.partner {
  background: #fff3e0;
}

.analysis-label {
  font-size: 26rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.analysis-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}

.result-advice {
  padding: 24rpx;
  background: #fff8e1;
  border-radius: 16rpx;
  border-left: 8rpx solid #ff9800;
}

.advice-text {
  font-size: 28rpx;
  color: #e65100;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 30rpx;
  padding-bottom: 40rpx;
}

.share-btn {
  background: linear-gradient(135deg, #4caf50, #43a047);
  color: white;
  font-size: 32rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.reset-btn {
  background: linear-gradient(135deg, #ff9800, #f57c00);
  color: white;
  font-size: 32rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
}

.home-btn {
  background: #e0e0e0;
  color: #666;
  font-size: 32rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
}
