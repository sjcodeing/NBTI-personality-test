.header {
  text-align: center;
  padding: 24px 20px;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  margin: -16px -16px 0 -16px;
  color: #fff;
}

.header-title {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 4px;
}

.header-desc {
  font-size: 13px;
  opacity: 0.8;
}

.ranking-list {
  margin: 16px;
}

.ranking-item {
  display: flex;
  align-items: center;
  gap: 12px;
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.rank-num {
  width: 32px;
  height: 32px;
  line-height: 32px;
  text-align: center;
  border-radius: 8px;
  background: #f0f0f0;
  color: #666;
  font-size: 16px;
  font-weight: 700;
  flex-shrink: 0;
}

.rank-num.top-1 {
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #fff;
}

.rank-num.top-2 {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
  color: #fff;
}

.rank-num.top-3 {
  background: linear-gradient(135deg, #cd7f32, #b87333);
  color: #fff;
}

.personality-info {
  flex: 1;
  min-width: 0;
}

.personality-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 4px;
}

.level-badge {
  display: inline-block;
  width: 24px;
  height: 24px;
  line-height: 24px;
  text-align: center;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  background: #999;
}

.level-s {
  background: linear-gradient(135deg, #ffd700, #ffaa00);
  color: #1a1a2e;
}

.level-a {
  background: linear-gradient(135deg, #c0c0c0, #a0a0a0);
  color: #1a1a2e;
}

.level-b {
  background: linear-gradient(135deg, #cd7f32, #b87333);
}

.level-c {
  background: linear-gradient(135deg, #666, #444);
}

.personality-name {
  font-size: 16px;
  font-weight: 700;
  color: #333;
}

.personality-alias {
  font-size: 12px;
  color: #999;
  margin-bottom: 6px;
}

.badges-preview {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.badges-preview text {
  font-size: 10px;
  background: #f5f5f5;
  padding: 2px 8px;
  border-radius: 10px;
  color: #666;
}

.count-info {
  text-align: right;
  flex-shrink: 0;
}

.count-num {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a2e;
}

.count-label {
  font-size: 11px;
  color: #999;
}
