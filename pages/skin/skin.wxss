.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20px 16px;
}

.header {
  text-align: center;
  margin-bottom: 32px;
}

.header-title {
  font-size: 24px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.header-sub {
  font-size: 14px;
  color: #999;
}

.skin-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.skin-card {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: all 0.2s;
  position: relative;
  border: 2px solid transparent;
}

.skin-card.selected {
  border-color: var(--skin-color);
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
}

.skin-card:active {
  transform: scale(0.98);
}

.skin-icon {
  font-size: 40px;
  margin-right: 16px;
  flex-shrink: 0;
}

.skin-info {
  flex: 1;
}

.skin-name {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 4px;
}

.skin-tagline {
  font-size: 13px;
  color: #888;
  line-height: 1.4;
}

.skin-check {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--skin-color);
  color: #fff;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12px;
}

.action-area {
  margin-top: 32px;
  padding: 0 8px;
}

.btn-start {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  border-radius: 12px;
  padding: 14px 0;
  border: none;
  width: 100%;
}

.btn-start[disabled] {
  background: #ccc;
  color: #fff;
}

.hint {
  text-align: center;
  font-size: 13px;
  color: #bbb;
  margin-top: 12px;
}
